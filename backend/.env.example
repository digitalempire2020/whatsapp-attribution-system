# =============================================
# WhatsApp Attribution System - Environment Variables
# =============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# --- Database (SQLite) ---
# Optional. Defaults to ./data/attribution.db
# DB_PATH=./data/attribution.db

# --- Whapi (WhatsApp API) ---
WHAPI_API_TOKEN=your_whapi_api_token_here
WHAPI_WEBHOOK_SECRET=your_webhook_verification_secret_here

# --- Google Ads (Enhanced Conversions) ---
GOOGLE_ADS_CUSTOMER_ID=123-456-7890
GOOGLE_ADS_CONVERSION_ACTION_ID=your_conversion_action_id
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret

# --- Meta / Facebook (Conversion API) ---
META_PIXEL_ID=your_pixel_id
META_ACCESS_TOKEN=your_access_token
META_TEST_EVENT_CODE=TEST12345

# --- GoHighLevel (Push UTM data to contacts) ---
# Required: GHL Private Integration Token (needs contacts.write scope)
GHL_API_KEY=your_ghl_private_integration_token
GHL_LOCATION_ID=your_ghl_location_id

# Custom field IDs — create these in GHL Settings → Custom Fields,
# then copy the field IDs here. Without these, UTM data won't be written.
# Field names to create: wa_utm_campaign, wa_utm_content, wa_utm_source, wa_utm_medium, wa_landing_url
GHL_CF_UTM_CAMPAIGN=custom_field_id_here
GHL_CF_UTM_CONTENT=custom_field_id_here
GHL_CF_UTM_SOURCE=custom_field_id_here
GHL_CF_UTM_MEDIUM=custom_field_id_here
GHL_CF_LANDING_URL=custom_field_id_here

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Security ---
# API key to protect /api/conversions and /api/metrics endpoints.
# If not set, these endpoints are open (dev mode).
API_KEY=your_secret_api_key_here

# Comma-separated list of allowed CORS origins.
# If not set, all origins are allowed (dev mode).
CORS_ALLOWED_ORIGINS=https://bellezza.com.sg,https://www.bellezza.com.sg
